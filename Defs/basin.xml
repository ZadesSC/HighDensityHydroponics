<Defs>
    <ThingDef Name="HDH_Hydroponics_base" ParentName="BuildingBase" Abstract="True">
        <description>An artificial nutrient bath that allows very dense crop growths in grow bays underneath. The nutrient pumps must work continuously; the plants will die if power is cut. Includes its own internal light source, but the internal ventilation system is not temperature controlled.</description>
        <thingClass>HighDensityHydro.Building_HighDensityHydro</thingClass>
        <minifiedDef>MinifiedThing</minifiedDef>
        <drawerType>MapMeshAndRealTime</drawerType>
        <thingCategories>
            <li>BuildingsProduction</li>
        </thingCategories>
        <castEdgeShadows>true</castEdgeShadows>
        <altitudeLayer>FloorEmplacement</altitudeLayer>
        <defaultPlacingRot>East</defaultPlacingRot>
        <passability>PassThroughOnly</passability>
        <pathCost>60</pathCost>
        <constructEffect>ConstructMetal</constructEffect>
        <fillPercent>0.30</fillPercent>
        <canOverlapZones>false</canOverlapZones>
        <constructionSkillPrerequisite>4</constructionSkillPrerequisite>
        <statBases>
            <WorkToBuild>2800</WorkToBuild>
            <MaxHitPoints>180</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <Cleanliness>-3</Cleanliness>
            <Mass>80</Mass>
        </statBases>
        <size>(1,4)</size>
        <!-- this stat doesn't do anything for this mod -->
        <fertility>2.8</fertility>
        <building>
            <defaultPlantToGrow>Plant_Rice</defaultPlantToGrow>
            <sowTag>Hydroponic</sowTag>
            <buildingTags>
                <li>Production</li>
            </buildingTags>
        </building>
        <tickerType>Rare</tickerType>
        <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
        <designationCategory>Production</designationCategory>
        <inspectorTabs>
            <li>HighDensityHydro.ITab_HDHDetails</li>
        </inspectorTabs>
    </ThingDef>

    <ThingDef ParentName="EtherealThingBase">
        <defName>HDH_BuiltInSunlampCellLight</defName>
        <label>hydroponics sunlamp cell light</label>
        <thingClass>ThingWithComps</thingClass>
        <tickerType>Never</tickerType>
        <selectable>false</selectable>
        <isAutoAttackableMapObject>false</isAutoAttackableMapObject>
        <comps>
            <li Class="CompProperties_Glower">
                <overlightRadius>1.1</overlightRadius>
                <glowRadius>1.0</glowRadius>
                <glowColor>(370,370,370,0)</glowColor>
            </li>
        </comps>
    </ThingDef>

    <ThingDef ParentName="HDH_Hydroponics_base">
        <defName>HDH_Hydroponics_mini</defName>
        <label>basic-density hydroponics bay</label>
        <description>An entry-tier dense hydroponics bay that fits 16 plants into a 1x4 footprint, yielding roughly four times the growing area of ordinary planting in the same space. It provides nutrient flow, but it still relies on sunlight, does not regulate temperature, and a power loss will kill the crop.</description>
        <graphicData>
            <texPath>HDHBasins/HDHBasinBr</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(1,4)</drawSize>
            <damageData>
                <cornerTL>Damage/Corner</cornerTL>
                <cornerTR>Damage/Corner</cornerTR>
                <cornerBL>Damage/Corner</cornerBL>
                <cornerBR>Damage/Corner</cornerBR>
            </damageData>
        </graphicData>
        <costList>
            <Steel>80</Steel>
            <ComponentIndustrial>1</ComponentIndustrial>
        </costList>
        <comps>
            <li Class="CompProperties_Forbiddable"/>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>300</basePowerConsumption>
            </li>
            <li Class="CompProperties_Flickable"/>
        </comps>
        <modExtensions>
            <li Class="HighDensityHydro.HydroStatsExtension">
                <fertility>2.8</fertility>
                <capacity>16</capacity>
                <powerConsumptionWhenSunlampOff>300</powerConsumptionWhenSunlampOff>
                <powerConsumptionWhenSunlampOn>425</powerConsumptionWhenSunlampOn>
            </li>
        </modExtensions>
        <researchPrerequisites>
            <li>HDH_BasicDensity</li>
        </researchPrerequisites>
    </ThingDef>
    
    <ThingDef ParentName="HDH_Hydroponics_base">
        <defName>HDH_Hydroponics</defName>
        <label>high-density hydroponics bay</label>
        <description>An industrial dense hydroponics bay that supports 80 plants in a 2x4 footprint, delivering roughly ten times the growing area of ordinary planting in the same space. Its nutrient circulation keeps the stack productive, but it still relies on sunlight and also needs steady power and external temperature control.</description>
        <graphicData>
            <texPath>HDHBasins/HDHBasin</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(2,4)</drawSize>
            <damageData>
                <cornerTL>Damage/Corner</cornerTL>
                <cornerTR>Damage/Corner</cornerTR>
                <cornerBL>Damage/Corner</cornerBL>
                <cornerBR>Damage/Corner</cornerBR>
            </damageData>
        </graphicData>
        <size>(2,4)</size>
        <costList>
            <Steel>180</Steel>
            <!-- <Plasteel>20</Plasteel> -->
            <ComponentIndustrial>2</ComponentIndustrial>
        </costList>
        <comps>
            <li Class="CompProperties_Forbiddable"/>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>1000</basePowerConsumption>
            </li>
            <li Class="CompProperties_Flickable"/>
        </comps>
        <modExtensions>
            <li Class="HighDensityHydro.HydroStatsExtension">
                <fertility>2.8</fertility>
                <capacity>80</capacity>
                <powerConsumptionWhenSunlampOff>1000</powerConsumptionWhenSunlampOff>
                <powerConsumptionWhenSunlampOn>1250</powerConsumptionWhenSunlampOn>
            </li>
        </modExtensions>
        <researchPrerequisites>
            <li>HDH_HighDensity</li>
        </researchPrerequisites>
    </ThingDef>
    
    <ThingDef ParentName="HDH_Hydroponics_base">
        <defName>HDH_Hydroponics_Hyper</defName>
        <label>ultra-density hydroponics bay</label>
        <description>An advanced ultra-dense hydroponics bay built for large indoor farms, packing 240 plants into a 2x6 footprint for roughly twenty times the growing area of ordinary planting in the same space. The stacked grow layers are extremely productive, but they still rely on sunlight and require continuous power and careful climate management to avoid a total crop loss.</description>
        <graphicData>
            <texPath>HDHBasins/HDHBasinDr</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(2,6)</drawSize>
            <damageData>
                <cornerTL>Damage/Corner</cornerTL>
                <cornerTR>Damage/Corner</cornerTR>
                <cornerBL>Damage/Corner</cornerBL>
                <cornerBR>Damage/Corner</cornerBR>
            </damageData>
        </graphicData>
        <size>(2,6)</size>
        <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
        <statBases>
            <WorkToBuild>3800</WorkToBuild>
            <MaxHitPoints>180</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <Cleanliness>-6</Cleanliness>
        </statBases>
        <costList>
            <Steel>360</Steel>
            <Plasteel>20</Plasteel>
            <ComponentSpacer>2</ComponentSpacer>
        </costList>
        <comps>
            <li Class="CompProperties_Forbiddable"/>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>2200</basePowerConsumption>
            </li>
            <li Class="CompProperties_Flickable"/>
        </comps>
        <modExtensions>
            <li Class="HighDensityHydro.HydroStatsExtension">
                <fertility>2.8</fertility>
                <capacity>240</capacity>
                <powerConsumptionWhenSunlampOff>2200</powerConsumptionWhenSunlampOff>
                <powerConsumptionWhenSunlampOn>2550</powerConsumptionWhenSunlampOn>
            </li>
        </modExtensions>
        <researchPrerequisites>
            <li>HDH_HighDensity_Ultra</li>
        </researchPrerequisites>
    </ThingDef>

    
    <ThingDef ParentName="HDH_Hydroponics_base">
        <defName>HDH_Hydroponics_Quantum</defName>
        <label>quantum-density hydroponics bay</label>
        <description>A spacer-grade quantum hydroponics chamber that folds multiple grow layers into a compact 2x2 footprint. Its base capacity scales upward with available power, and the chamber ignores ordinary light and temperature limits, turning energy supply into the main constraint on production.</description>
        <graphicData>
            <texPath>HDHBasins/HDHBasinQt</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(2,2)</drawSize>
            <damageData>
                <cornerTL>Damage/Corner</cornerTL>
                <cornerTR>Damage/Corner</cornerTR>
                <cornerBL>Damage/Corner</cornerBL>
                <cornerBR>Damage/Corner</cornerBR>
            </damageData>
        </graphicData>
        <size>(2,2)</size>
        <defaultPlacingRot>North</defaultPlacingRot>
        <statBases>
            <WorkToBuild>7600</WorkToBuild>
            <MaxHitPoints>180</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <Cleanliness>-6</Cleanliness>
        </statBases>
        <costList>
            <Steel>500</Steel>
            <Plasteel>50</Plasteel>
            <ComponentIndustrial>4</ComponentIndustrial>
            <ComponentSpacer>4</ComponentSpacer>
        </costList>
        <comps>
            <li Class="CompProperties_Forbiddable"/>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>2500</basePowerConsumption>
            </li>
            <li Class="CompProperties_Flickable"/>
        </comps>
        <modExtensions>
            <li Class="HighDensityHydro.HydroStatsExtension">
                <fertility>4.2</fertility>
                <capacity>0</capacity>
                <requiresLightCheck>true</requiresLightCheck>
                <requiresTemperatureCheck>false</requiresTemperatureCheck>
                <requiresAtmosphereCheck>true</requiresAtmosphereCheck>
                <powerScalesCapacity>true</powerScalesCapacity>
                <powerConsumptionWhenSunlampOff>2500</powerConsumptionWhenSunlampOff>
                <powerConsumptionWhenSunlampOn>2800</powerConsumptionWhenSunlampOn>
                <basePowerIncrease>20</basePowerIncrease>
                <basePowerIncreaseWhenSunlampOff>20</basePowerIncreaseWhenSunlampOff>
                <basePowerIncreaseWhenSunlampOn>25</basePowerIncreaseWhenSunlampOn>
                <capacityExponent>1.05</capacityExponent>
                <capacityExponentWhenSunlampOff>1.05</capacityExponentWhenSunlampOff>
                <capacityExponentWhenSunlampOn>1.05</capacityExponentWhenSunlampOn>
                <plantsPerLayer>4</plantsPerLayer>
                <defaultPowerScalingLevel>20</defaultPowerScalingLevel>
            </li>
        </modExtensions>
        <researchPrerequisites>
            <li>HDH_HighDensity_Quantum</li>
        </researchPrerequisites>
        <building>
            <defaultPlantToGrow>Plant_Rice</defaultPlantToGrow>
            <sowTag>Ground</sowTag>
        </building>
    </ThingDef>
</Defs>
